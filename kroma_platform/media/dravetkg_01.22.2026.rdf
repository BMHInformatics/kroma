  <rdf:Description rdf:about="http://example.org/dravet-syndrome/StatisticalAnalysis">
    <ds:uses rdf:resource="http://example.org/dravet-syndrome/ANOVA"/>
    <ds:uses rdf:resource="http://example.org/dravet-syndrome/ChiSquareTest"/>
    <ds:uses rdf:resource="http://example.org/dravet-syndrome/PairedTTest"/>
    <ds:uses rdf:resource="http://example.org/dravet-syndrome/WelchTTest"/>
