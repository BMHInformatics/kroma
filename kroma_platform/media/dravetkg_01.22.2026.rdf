    <ds:hasAstrogliosisValue>((FibrillaryAstrogliosis and (isLocatedAt only CA2Field)) or (Gliosis and (isLocatedAt only CA2Field)) or (ModerateAstrogliosis and (isLocatedAt only CA2Field)))</ds:hasAstrogliosisValue>
    <ds:hasAstrogliosisValue>((FibrillaryAstrogliosis and (isLocatedAt only CA3Field)) or (Gliosis and (isLocatedAt only CA3Field)) or (ModerateAstrogliosis and (isLocatedAt only CA3Field)))</ds:hasAstrogliosisValue>
    <ds:hasAstrogliosisValue>((FibrillaryAstrogliosis and (isLocatedAt only DentateGyrusHippocampus)) or (Gliosis and (isLocatedAt only DentateGyrusHippocampus))or(ModerateAstrogliosisand(isLocatedAtonlyDentateGyrusHippocampus)))</ds:hasAstrogliosisValue>
    <ds:hasAstrogliosisValue>((Gliosis and (isLocatedAt only Subiculum)) or (ModerateAstrogliosis and (isLocatedAt only Subiculum)))</ds:hasAstrogliosisValue>
    <ds:hasAstrogliosisValue>(FibrillaryAstrogliosis and (isLocatedAt only CA1Field))</ds:hasAstrogliosisValue>
    <ds:hasAstrogliosisValue>(FibrillaryAstrogliosis and (isLocatedAt only CA4Field))</ds:hasAstrogliosisValue>
    <ds:hasNeuronalLossValue>((ModerateNeuronalLoss and (isLocatedAt only CA2Field)) or (NoNeuronalLoss and (isLocatedAt only CA2Field)) or (SevereNeuronalLoss and (isLocatedAt only CA2Field)))</ds:hasNeuronalLossValue>
    <ds:hasNeuronalLossValue>((ModerateNeuronalLoss and (isLocatedAt only CA3Field)) or (NoNeuronalLoss and (isLocatedAt only CA3Field)) or (SevereNeuronalLoss and (isLocatedAt only CA3Field)))</ds:hasNeuronalLossValue>
    <ds:hasNeuronalLossValue>((ModerateNeuronalLoss and (isLocatedAt only DentateGyrusHippocampus)) or (NoNeuronalLoss and (isLocatedAt only DentateGyrusHippocampus)) or (SevereNeuronalLoss and (isLocatedAt only DentateGyrusHippocampus)))</ds:hasNeuronalLossValue>
    <ds:hasNeuronalLossValue>((ModerateNeuronalLoss and (isLocatedAt only Subiculum)) or (NoNeuronalLoss and (isLocatedAt only Subiculum)))</ds:hasNeuronalLossValue>
    <ds:hasNeuronalLossValue>(SevereNeuronalLoss and (isLocatedAt only CA1Field))</ds:hasNeuronalLossValue>
    <ds:hasNeuronalLossValue>(SevereNeuronalLoss and (isLocatedAt only CA4Field))</ds:hasNeuronalLossValue>
