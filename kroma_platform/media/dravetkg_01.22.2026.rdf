    <ds:testedIn rdf:resource="http://example.org/dravet-syndrome/ZebrafishDravetModel"/>
    <ds:ameliorates rdf:resource="http://example.org/dravet-syndrome/Hyperactivity"/>
    <ds:ameliorates rdf:resource="http://example.org/dravet-syndrome/MyoclonicSeizurePattern"/>
    <ds:ameliorates rdf:resource="http://example.org/dravet-syndrome/ConvulsiveSeizures"/>
    <ds:ameliorates rdf:resource="http://example.org/dravet-syndrome/ElectrophysiologicalAbnormalities"/>
    <ds:ameliorates rdf:resource="http://example.org/dravet-syndrome/HyperthermiaSensitivity"/>
